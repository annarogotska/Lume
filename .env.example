# Supabase — public (safe to expose in the client bundle)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Edge Function secrets are NOT set here — set them with the Supabase CLI:
#   supabase secrets set RESEND_API_KEY=re_xxx CONTACT_TO_EMAIL=you@domain.com
#   (optional) CONTACT_FROM_EMAIL="Nuvel <hello@yourdomain.com>"
